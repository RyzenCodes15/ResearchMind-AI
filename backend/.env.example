APP_NAME=ResearchMind AI
APP_DESCRIPTION=AI research assistant built with FastAPI and RAG
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=researchmind
POSTGRES_PASSWORD=researchmind
POSTGRES_DB=researchmind
DATABASE_URL=postgresql+psycopg://researchmind:researchmind@postgres:5432/researchmind
BACKEND_CORS_ORIGINS=http://localhost:3000
DOCUMENT_STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
CHAT_TOP_K=5
CHAT_MIN_SIMILARITY=0.2